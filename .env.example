# Software Engineer Agentic CLI (SEA CLI) — build-time configuration.
#
# CLI_COMMAND_NAME controls what shell command this CLI installs as (via `npm link`
# / `npm install -g .`). Change this if "devx" collides with something else on your
# system or you'd rather brand it differently — then re-run `npm run build` (which
# regenerates package.json's "bin" field and src/generated/brand.ts) before linking.
CLI_COMMAND_NAME=devx

# provider to use for LLM calls. Currently only "deepseek" is supported. .env is in the workspace
DEVX_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-...
DEVX_MODEL=deepseek-chat
